{
  "info": {
    "_postman_id": "8a4bde30-1453-4e26-b6f2-8d798d9973f9",
    "name": "Excise Tax API - Stamps & Labels",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for Stamps & Labels lifecycle: Generate -> Issue -> Assign -> Apply -> Activate -> Track -> Verify -> Audit, including public verification and enforcement."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001" },
    { "key": "apiPrefix", "value": "/v1" },
    { "key": "token", "value": "" },
    { "key": "organizationId", "value": "" },
    { "key": "facilityId", "value": "" },
    { "key": "stampRequestId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "stampLabelId", "value": "" },
    { "key": "stampUid", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+2519XXXXXXXX\",\n  \"pin\": \"1234\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "const token = res?.data?.[0]?.accessToken || res?.data?.accessToken || res?.accessToken;",
              "const orgId = res?.data?.[0]?.organizationId || res?.data?.organizationId || res?.organizationId;",
              "if (token) pm.collectionVariables.set('token', token);",
              "if (orgId) pm.collectionVariables.set('organizationId', orgId);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Excise - Create Facility",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "x-organization-id", "value": "{{organizationId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Stamp Facility Addis\",\n  \"facilityType\": \"FACTORY\",\n  \"licenseNumber\": \"FAC-ET-2026-001\",\n  \"region\": \"Addis Ababa\",\n  \"zone\": \"Arada\",\n  \"woreda\": \"01\",\n  \"city\": \"Addis Ababa\",\n  \"addressLine1\": \"Mexico Square Industrial Area\",\n  \"addressLine2\": \"Block B\",\n  \"isActive\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/excise/facilities",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "excise", "facilities"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "const row = res?.data?.[0] || res?.data;",
              "if (row?.id) pm.collectionVariables.set('facilityId', row.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Excise - Create Stamp Request",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "x-organization-id", "value": "{{organizationId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"facilityId\": \"{{facilityId}}\",\n  \"goodsCategory\": \"Beverage\",\n  \"goodsDescription\": \"Excisable Beverage 500ml\",\n  \"quantity\": 1000,\n  \"requiredByDate\": \"2026-08-01T08:00:00.000Z\",\n  \"plannedProductionOrImportDate\": \"2026-08-05T08:00:00.000Z\",\n  \"attachmentUrl\": \"https://example.com/supporting-doc.pdf\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/excise/stamp-requests",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "excise", "stamp-requests"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "const row = res?.data?.[0] || res?.data;",
              "if (row?.id) pm.collectionVariables.set('stampRequestId', row.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Excise - Add Stamp Request Payment",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "x-organization-id", "value": "{{organizationId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"stampFeeAmount\": 25000,\n  \"stampFeeCurrency\": \"ETB\",\n  \"paymentReference\": \"PAY-ET-2026-7788\",\n  \"paymentProofUrl\": \"https://example.com/payment-proof.pdf\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/excise/stamp-requests/{{stampRequestId}}/payment",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "excise", "stamp-requests", "{{stampRequestId}}", "payment"]
        }
      }
    },
    {
      "name": "Excise - Submit Stamp Request",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "x-organization-id", "value": "{{organizationId}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/excise/stamp-requests/{{stampRequestId}}/submit",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "excise", "stamp-requests", "{{stampRequestId}}", "submit"]
