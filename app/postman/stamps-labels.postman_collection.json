        "body": {
          "mode": "raw",
          "raw": "{\n  \"decision\": \"APPROVED\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/excise/admin/stamp-requests/{{stampRequestId}}/review",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "excise", "admin", "stamp-requests", "{{stampRequestId}}", "review"]
        }
      }
    },
    {
      "name": "Stamps & Labels - Generate",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "x-organization-id", "value": "{{organizationId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"count\": 1,\n  \"stampRequestId\": \"{{stampRequestId}}\",\n  \"uidPrefix\": \"ET-EXS\",\n  \"digitalLinkBase\": \"https://verify.ers.gov.et/stamps\",\n  \"codeFormat\": \"GS1_DATAMATRIX\",\n  \"operatorType\": \"MANUFACTURER\",\n  \"operatorName\": \"Abebe Beverages PLC\",\n  \"operatorTin\": \"0012345678\",\n  \"operatorLicenseNumber\": \"ET-EXC-2026-0001\",\n  \"ethiopiaRevenueOffice\": \"Addis Ababa Large Taxpayers Office\",\n  \"productId\": \"{{productId}}\",\n  \"productName\": \"Excisable Beverage 500ml\",\n  \"packageLevel\": \"UNIT\",\n  \"batchNumber\": \"BATCH-APR-2026-01\",\n  \"productionDate\": \"2026-04-09T07:00:00.000Z\",\n  \"forecastReference\": \"FORECAST-2026-APR\",\n  \"forecastSubmittedAt\": \"2026-01-01T08:00:00.000Z\",\n  \"requiresSixtyDayForecast\": true,\n  \"isImported\": false,\n  \"metadata\": {\n    \"country\": \"ET\",\n    \"standard\": \"WHO-FCTC-ITP\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/stamps-labels/admin/generate",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "stamps-labels", "admin", "generate"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "const payload = res?.data?.[0] || res?.data;",
              "const first = payload?.stamps?.[0];",
              "if (first?.id) pm.collectionVariables.set('stampLabelId', first.id);",
              "if (first?.stampUid) pm.collectionVariables.set('stampUid', first.stampUid);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
