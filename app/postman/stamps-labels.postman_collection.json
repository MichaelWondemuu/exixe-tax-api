      }
    },
    {
      "name": "Excise Admin - Approve Stamp Request",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "x-organization-id", "value": "{{organizationId}}" }
