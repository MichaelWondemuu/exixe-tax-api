{
  "name": "government excise platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch . --ignore dist --ignore node_modules --ext js --exec \"node app.js\"",
    "start": "node app.js",
    "migration:create": "sequelize-cli migration:generate --name",
    "migration:run": "sequelize-cli db:migrate",
    "migration:revert": "sequelize-cli db:migrate:undo",
    "migration:status": "sequelize-cli db:migrate:status",
    "db:seed": "sequelize-cli db:seed:all",
    "db:sync": "node scripts/sync-models.js"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "casbin": "^5.28.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.0.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.33",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",
    "sequelize": "^6.35.2",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "sequelize-cli": "^6.6.2"
  },
  "bin": "app.js",
  "pkg": {
    "scripts": [
      "app.js"
    ],
    "assets": [
      "redoc.html",
      "swagger.json",
      "uploads/**/*",
      "views/**/*",
      ".env"
    ],
    "outputPath": "app"
  }
}