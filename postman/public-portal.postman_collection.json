            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTION_TAKEN\",\n  \"note\": \"Field inspection completed and action applied.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/portal/admin/reports/{{reportReference}}",
              "host": ["{{baseUrl}}"],
              "path": ["portal", "admin", "reports", "{{reportReference}}"]
            }
          }
        },
        {
          "name": "Update Report Status - Closed",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CLOSED\",\n  \"note\": \"Case resolved and closed.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/portal/admin/reports/{{reportReference}}",
              "host": ["{{baseUrl}}"],
              "path": ["portal", "admin", "reports", "{{reportReference}}"]
            }
          }
        },
        {
          "name": "Create Notification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reporterId\": \"{{reporterId}}\",\n  \"type\": \"ALERT\",\n  \"title\": \"Fraud alert\",\n  \"message\": \"Please avoid suspicious products and report immediately.\",\n  \"payload\": {\n    \"severity\": \"HIGH\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/portal/admin/notifications",
              "host": ["{{baseUrl}}"],
              "path": ["portal", "admin", "notifications"]
            }
          }
        },
        {
          "name": "Create Broadcast Notification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"ALERT\",\n  \"title\": \"Public warning\",\n  \"message\": \"Avoid products with invalid excise stamps.\",\n  \"payload\": {\n    \"scope\": \"PUBLIC\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/portal/admin/notifications",
              "host": ["{{baseUrl}}"],
              "path": ["portal", "admin", "notifications"]
            }
          }
