{
  "info": {
    "name": "Enforcement Reconciliation API",
    "_postman_id": "8f3f83de-5a0a-42a8-b97f-9a2f7f760001",
    "description": "Covers counterfeit reports/cases, suspicious product reports, recalls, production & stock records, and reconciliation runs under /v1/enforcement.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/v1" },
    { "key": "authToken", "value": "" },
    { "key": "systemAuthToken", "value": "" },
    { "key": "organizationId", "value": "" },
    { "key": "facilityId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "productVariantId", "value": "" },
    { "key": "counterfeitReportId", "value": "" },
    { "key": "counterfeitCaseId", "value": "" },
    { "key": "suspiciousProductReportId", "value": "" },
    { "key": "recallId", "value": "" },
    { "key": "productionRecordId", "value": "" },
    { "key": "stockSnapshotId", "value": "" },
    { "key": "reconciliationRunId", "value": "" }
