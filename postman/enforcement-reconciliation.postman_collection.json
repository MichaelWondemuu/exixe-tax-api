  "item": [
    {
      "name": "Authenticated Operators",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
      },
      "item": [
        {
          "name": "Counterfeit Reports",
          "item": [
            {
              "name": "Create Counterfeit Report",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const id = pm.response.json()?.data?.[0]?.id;",
                      "if (id) pm.collectionVariables.set('counterfeitReportId', id);"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": {
                  "raw": "{{baseUrl}}/enforcement/counterfeit-reports",
                  "host": ["{{baseUrl}}"],
                  "path": ["enforcement", "counterfeit-reports"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"description\": \"Suspected counterfeit items found in market\",\n  \"productId\": \"{{productId}}\",\n  \"facilityId\": \"{{facilityId}}\",\n  \"stampIdentifier\": \"STAMP-ABC-001\"\n}"
                }
              }
            }
          ]
        },
        {
